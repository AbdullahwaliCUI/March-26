      <!-- Typing Animation Script -->
      <script type='text/javascript'>
        document.addEventListener(&#39;DOMContentLoaded&#39;, function() {
          const typingElement = document.getElementById(&#39;typing-text&#39;);
          if (!typingElement) return;
          
          const texts = [
            &#39;is a Professional Politician&#39;,
            &#39;is a Community Leader&#39;,
            &#39;is a Public Servant&#39;,
            &#39;is a Change Maker&#39;,
            &#39;is a Voice for the People&#39;,
            &#39;is a Future Senator&#39;,
            &#39;is a Youth Advocate&#39;,
            &#39;is a Political Reformer&#39;
          ];
          
          let textIndex = 0;
          let charIndex = 0;
          let isDeleting = false;
          let typeSpeed = 100;
          let deleteSpeed = 50;
          let pauseTime = 2000;
          
          function typeText() {
            const currentText = texts[textIndex];
            
            if (isDeleting) {
              typingElement.textContent = currentText.substring(0, charIndex - 1);
              charIndex--;
              typeSpeed = deleteSpeed;
            } else {
              typingElement.textContent = currentText.substring(0, charIndex + 1);
              charIndex++;
              typeSpeed = 100;
            }
            
            if (!isDeleting &amp;&amp; charIndex === currentText.length) {
              typeSpeed = pauseTime;
              isDeleting = true;
            } else if (isDeleting &amp;&amp; charIndex === 0) {
              isDeleting = false;
              textIndex = (textIndex + 1) % texts.length;
            }
            
            setTimeout(typeText, typeSpeed);
          }
          
          typeText();
        });
      </script>
      
      <!-- Campaign Popup Script -->
      <script type='text/javascript'>
        (function() {
          &#39;use strict&#39;;
          
          var popupShown = false;
          
          function showPopup() {
            var popupOverlay = document.getElementById(&#39;campaign-popup-overlay&#39;);
            if (!popupOverlay) {
              // Retry after a short delay if element not found
              setTimeout(showPopup, 100);
              return;
            }
            
            // Check localStorage
            var dontShowAgain = localStorage.getItem(&#39;campaign-popup-dont-show&#39;);
            
            if (dontShowAgain !== &#39;true&#39;) {
              if (!popupShown) {
                // Show popup - use multiple methods to ensure it shows
                popupOverlay.style.display = &#39;flex&#39;;
                popupOverlay.style.opacity = &#39;1&#39;;
                popupOverlay.style.visibility = &#39;visible&#39;;
                popupOverlay.classList.add(&#39;active&#39;);
                document.body.style.overflow = &#39;hidden&#39;;
                popupShown = true;
              }
            } else if (dontShowAgain === &#39;true&#39;) {
              // Hide if disabled
              popupOverlay.style.display = &#39;none&#39;;
            }
          }
          
          function setupPopupHandlers() {
            var popupOverlay = document.getElementById(&#39;campaign-popup-overlay&#39;);
            var closeBtn = document.getElementById(&#39;campaign-popup-close&#39;);
            
            if (!popupOverlay) return;
            
            function closePopup() {
              popupOverlay.classList.remove(&#39;active&#39;);
              popupOverlay.style.opacity = &#39;0&#39;;
              popupOverlay.style.visibility = &#39;hidden&#39;;
              document.body.style.overflow = &#39;&#39;;
            }
            
            // Close button
            if (closeBtn) {
              closeBtn.addEventListener(&#39;click&#39;, closePopup);
            }
            
            // Close on overlay click
            popupOverlay.addEventListener(&#39;click&#39;, function(e) {
              if (e.target === popupOverlay) {
                closePopup();
              }
            });
            
            // Close on Escape key
            document.addEventListener(&#39;keydown&#39;, function(e) {
              if (e.key === &#39;Escape&#39;) {
                if (popupOverlay.classList.contains(&#39;active&#39;)) {
                  closePopup();
                }
              }
            });
          }
          
          // Initialize when page loads - Multiple methods to ensure it works
          function initPopup() {
            setupPopupHandlers();
            setTimeout(showPopup, 800);
          }
          
          // Method 1: DOMContentLoaded
          if (document.readyState === &#39;loading&#39;) {
            document.addEventListener(&#39;DOMContentLoaded&#39;, initPopup);
          } else {
            // DOM already loaded
            initPopup();
          }
          
          // Method 2: Window load (fallback)
          window.addEventListener(&#39;load&#39;, function() {
            setTimeout(function() {
              if (!popupShown) {
                showPopup();
              }
            }, 1000);
          });
          
          // Method 3: Immediate check after a delay
          setTimeout(function() {
            if (!popupShown) {
              var popupOverlay = document.getElementById(&#39;campaign-popup-overlay&#39;);
              if (popupOverlay) {
                showPopup();
              }
            }
          }, 1500);
        })();
      </script>
