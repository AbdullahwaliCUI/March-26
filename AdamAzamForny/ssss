      <!-- Blog Post Link Handler Script -->
      <script type='text/javascript'>
        // Ensure blog post links work correctly
        document.addEventListener(&#39;DOMContentLoaded&#39;, function() {
          // Add click handlers to blog post links
          const blogLinks = document.querySelectorAll(&#39;.blog-read-more, .blog-post-title a&#39;);
          
          blogLinks.forEach(function(link) {
            link.addEventListener(&#39;click&#39;, function(e) {
              // Ensure the link has a valid href
              if (this.href &amp;&amp; this.href !== &#39;#&#39; &amp;&amp; this.href !== &#39;javascript:void(0)&#39;) {
                // Let the default link behavior handle navigation
                return true;
              } else {
                e.preventDefault();
                console.log(&#39;Blog post link clicked but no valid URL found&#39;);
              }
            });
          });
          
          // Debug: Log all blog post links
          console.log(&#39;Found &#39; + blogLinks.length + &#39; blog post links&#39;);
          blogLinks.forEach(function(link, index) {
            console.log(&#39;Link &#39; + index + &#39;:&#39;, link.href);
          });
        });
      </script>
      
      <!-- Mobile Menu Toggle Script -->
      <script type='text/javascript'>
        document.addEventListener(&#39;DOMContentLoaded&#39;, function() {
          const mobileMenuToggle = document.getElementById(&#39;mobile-menu-toggle&#39;);
          const navMenu = document.getElementById(&#39;nav-menu&#39;);
          
          if (mobileMenuToggle &amp;&amp; navMenu) {
            mobileMenuToggle.addEventListener(&#39;click&#39;, function() {
              navMenu.classList.toggle(&#39;active&#39;);
              mobileMenuToggle.classList.toggle(&#39;active&#39;);
            });
            
            // Close menu when clicking on a link
            const navLinks = navMenu.querySelectorAll(&#39;a&#39;);
            navLinks.forEach(function(link) {
              link.addEventListener(&#39;click&#39;, function() {
                navMenu.classList.remove(&#39;active&#39;);
                mobileMenuToggle.classList.remove(&#39;active&#39;);
              });
            });
            
            // Close menu when clicking outside
            document.addEventListener(&#39;click&#39;, function(e) {
              if (!mobileMenuToggle.contains(e.target) &amp;&amp; !navMenu.contains(e.target)) {
                navMenu.classList.remove(&#39;active&#39;);
                mobileMenuToggle.classList.remove(&#39;active&#39;);
              }
            });
          }
        });
      </script>
      
      <!-- Pictures Page Script -->
      <script type='text/javascript'>
        document.addEventListener(&#39;DOMContentLoaded&#39;, function() {
          // Add pictures-page class to body when on pictures page
          if (window.location.pathname.includes(&#39;/p/pictures.html&#39;) || 
              window.location.pathname.includes(&#39;/p/pictures&#39;)) {
            document.body.classList.add(&#39;pictures-page&#39;);
          }
          
          // Add videos-page class to body when on videos page
          if (window.location.pathname.includes(&#39;/p/videos.html&#39;) || 
              window.location.pathname.includes(&#39;/p/videos&#39;)) {
            document.body.classList.add(&#39;videos-page&#39;);
          }
          
          // Picture card hover effects
          const pictureCards = document.querySelectorAll(&#39;.picture-card&#39;);
          pictureCards.forEach(function(card) {
            card.addEventListener(&#39;mouseenter&#39;, function() {
              this.style.transform = &#39;translateY(-8px) scale(1.02)&#39;;
            });
            
            card.addEventListener(&#39;mouseleave&#39;, function() {
              this.style.transform = &#39;translateY(0) scale(1)&#39;;
            });
          });
          
          // Video card hover effects
          const videoCards = document.querySelectorAll(&#39;.video-card&#39;);
          videoCards.forEach(function(card) {
            card.addEventListener(&#39;mouseenter&#39;, function() {
              this.style.transform = &#39;translateY(-8px) scale(1.02)&#39;;
            });
            
            card.addEventListener(&#39;mouseleave&#39;, function() {
              this.style.transform = &#39;translateY(0) scale(1)&#39;;
